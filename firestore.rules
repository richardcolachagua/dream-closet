rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function hasOnlyKeys(data, allowed) {
      return data.keys().hasOnly(allowed);
    }

    function onboardingIsValid(data) {
      return data is map
        && hasOnlyKeys(data, ["gender", "categories", "brands", "completed"])
        && (
          !('gender' in data)
          || data.gender == null
          || data.gender is string
        )
        && data.categories is list
        && data.brands is list
        && data.completed is bool;
    }

    function preferencesIsValid(data) {
      return data is map
        && hasOnlyKeys(data, ["emailNotifications"])
        && data.emailNotifications is bool;
    }

    function userCreateIsValid(userId) {
      return isOwner(userId)
        && hasOnlyKeys(request.resource.data, [
          "firstName",
          "lastName",
          "email",
          "onboarding",
          "preferences",
          "createdAt",
          "updatedAt"
        ])
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.email is string
        && onboardingIsValid(request.resource.data.onboarding)
        && (
          !('preferences' in request.resource.data)
          || preferencesIsValid(request.resource.data.preferences)
        )
        && request.resource.data.createdAt is timestamp
        && request.resource.data.updatedAt is timestamp;
    }

    function userUpdateIsValid(userId) {
      return isOwner(userId)
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.email is string
        && onboardingIsValid(request.resource.data.onboarding)
        && (
          !('preferences' in request.resource.data)
          || preferencesIsValid(request.resource.data.preferences)
        )
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedAt is timestamp
        && (
          !('subscription' in request.resource.data)
          || !('subscription' in resource.data)
          || request.resource.data.subscription == resource.data.subscription
        );
    }

    function savedItemIsValid() {
      return hasOnlyKeys(request.resource.data, [
        "userId",
        "itemId",
        "name",
        "imageUrl",
        "price",
        "numericPrice",
        "productUrl",
        "brand",
        "source",
        "description",
        "createdAt"
      ])
      && request.resource.data.userId is string
      && request.resource.data.itemId is string
      && request.resource.data.name is string
      && request.resource.data.imageUrl is string
      && request.resource.data.price is string
      && (
        !('numericPrice' in request.resource.data)
        || request.resource.data.numericPrice == null
        || request.resource.data.numericPrice is int
        || request.resource.data.numericPrice is float
      )
      && request.resource.data.productUrl is string
      && request.resource.data.brand is string
      && request.resource.data.source is string
      && request.resource.data.description is string
      && request.resource.data.createdAt is timestamp;
    }

    function savedSearchIsValid() {
      return hasOnlyKeys(request.resource.data, [
        "userId",
        "query",
        "filters",
        "sort",
        "page",
        "createdAt"
      ])
      && request.resource.data.userId is string
      && request.resource.data.query is string
      && request.resource.data.filters is map
      && request.resource.data.sort is string
      && request.resource.data.page is int
      && request.resource.data.createdAt is timestamp;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if userCreateIsValid(userId);
      allow update: if userUpdateIsValid(userId);
      allow delete: if isOwner(userId);
    }

    match /saved-items/{docId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && savedItemIsValid();
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && savedItemIsValid();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /saved-searches/{docId} {
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow list: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && savedSearchIsValid();
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.createdAt == resource.data.createdAt
        && savedSearchIsValid();
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}